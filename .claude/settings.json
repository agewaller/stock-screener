{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(git status:*)",
      "Bash(git status)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git rev-parse:*)",
      "Bash(git remote:*)",
      "Bash(git ls-remote:*)",
      "Bash(git ls-files:*)",
      "Bash(git config --get:*)",
      "Bash(git blame:*)",
      "Bash(git fetch:*)",
      "Bash(git stash list)",
      "Bash(git stash show:*)",
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(wc:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(cat:*)",
      "Bash(file:*)",
      "Bash(stat:*)",
      "Bash(node -c:*)",
      "Bash(node --check:*)",
      "Bash(npx prettier --check:*)",
      "Bash(npx eslint:*)",
      "Bash(npm ls:*)",
      "Bash(npm view:*)",
      "Bash(mkdir -p:*)",
      "Bash(chmod +x:*)"
    ],
    "deny": [
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -fd:*)",
      "Bash(rm -rf:*)",
      "Bash(localStorage.clear:*)"
    ]
  }
}
