{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "cares-relay",
  "main": "worker/relay.js",
  "compatibility_date": "2026-04-06",
  "observability": {
    "enabled": true
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  // Service binding: cares-relay → stock-screener (internal call,
  // bypasses Cloudflare Access protecting the proxy's public URL).
  // stock-screener is the worker that actually exists in the account
  // and holds ANTHROPIC_API_KEY / ADMIN_WRITE_TOKEN secrets and the
  // RESEARCH_KV binding. Binding to a not-yet-created service name
  // ("cares-ai-proxy") makes the relay deploy itself fail.
  "services": [
    { "binding": "PROXY", "service": "stock-screener" }
  ]
  // NOTE: ai.cares.advisers.jp の custom_domain route は一時撤去。
  // advisers.jp ゾーンが Cloudflare アカウントから削除されており
  // (公開 DNS でも未解決)、route を宣言すると deploy 自体が失敗する。
  // ゾーンを Cloudflare に再追加したら以下を戻すこと:
  //   "routes": [{ "pattern": "ai.cares.advisers.jp", "custom_domain": true }]
}
