# Personal Learning Companion — Worker environment variables
#
# Copy to .dev.vars (for local wrangler dev) or register as Cloudflare
# Secrets for production:
#   wrangler secret put ANTHROPIC_API_KEY --config wrangler.learning.toml
#   wrangler secret put FIREBASE_PROJECT_ID --config wrangler.learning.toml
#   wrangler secret put FIREBASE_SERVICE_ACCOUNT_JSON --config wrangler.learning.toml
#
# NEVER commit .dev.vars or real keys.

# Anthropic API key — used by the orchestrator to call Claude.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Firebase project id (same project as 健康日記: care-14c31).
FIREBASE_PROJECT_ID=care-14c31

# Firebase Admin service-account JSON (stringified, single line).
# Used to verify Firebase ID tokens and to read server-side-only
# prompt documents that are locked away from all clients.
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"care-14c31","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"firebase-adminsdk-xxxxx@care-14c31.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}

# Admin emails (comma-separated). The orchestrator re-checks these
# on every admin API call — the client-side isAdmin() flag alone is
# never trusted.
ADMIN_EMAILS=agewaller@gmail.com

# App name override (仕様 §1 — allow rename without code change).
APP_NAME=Personal Learning Companion
