{
  "$schema": "node_modules/wrangler/config-schema.json",
  // name は既存ワーカー "stock-screener" を維持する。"cares-ai-proxy" に
  // リネームすると新規ワーカーが作られ、既存の secrets
  // (ANTHROPIC_API_KEY / ADMIN_WRITE_TOKEN) と RESEARCH_KV バインディングを
  // 引き継がないため、デプロイ成功と同時に AI が鍵なしで死ぬ。
  "name": "stock-screener",
  "main": "worker/anthropic-proxy.js",
  "compatibility_date": "2026-04-06",
  // ダッシュボードで設定済みの plain-text vars (FIREBASE_PROJECT_ID,
  // ALLOWED_ORIGINS) をデプロイで消さない
  "keep_vars": true,
  "observability": {
    "enabled": true
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "vars": {
    "ALLOWED_ORIGINS": "https://cares.advisers.jp",
    "FIREBASE_PROJECT_ID": "care-14c31"
  },
  // Production AI entrypoint. Keep this on stock-screener directly so
  // the app no longer depends on the legacy cares-relay workers.dev URL.
  "routes": [
    { "pattern": "ai.cares.advisers.jp", "custom_domain": true }
  ],
  // The deploy workflow replaces this placeholder with the real ID for
  // the `stock-screener-research` KV namespace before wrangler deploy.
  "kv_namespaces": [
    {
      "binding": "RESEARCH_KV",
      "id": "REPLACE_WITH_STOCK_SCREENER_RESEARCH_KV_ID"
    }
  ]
}
