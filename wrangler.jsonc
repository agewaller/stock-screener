{
  "$schema": "node_modules/wrangler/config-schema.json",
  // name は既存ワーカー "stock-screener" を維持する。"cares-ai-proxy" に
  // リネームすると新規ワーカーが作られ、既存の secrets
  // (ANTHROPIC_API_KEY / ADMIN_WRITE_TOKEN) と RESEARCH_KV バインディングを
  // 引き継がないため、デプロイ成功と同時に AI が鍵なしで死ぬ。
  "name": "stock-screener",
  "main": "worker/anthropic-proxy.js",
  "compatibility_date": "2026-04-06",
  // ダッシュボードで設定済みの plain-text vars (FIREBASE_PROJECT_ID,
  // ALLOWED_ORIGINS) をデプロイで消さない
  "keep_vars": true,
  "observability": {
    "enabled": true
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
