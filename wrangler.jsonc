{
  "$schema": "node_modules/wrangler/config-schema.json",
  // name は既存ワーカー "stock-screener" を維持する。"cares-ai-proxy" に
  // リネームすると新規ワーカーが作られ、既存の secrets
  // (ANTHROPIC_API_KEY / ADMIN_WRITE_TOKEN) と RESEARCH_KV バインディングを
  // 引き継がないため、デプロイ成功と同時に AI が鍵なしで死ぬ。
  "name": "stock-screener",
  "main": "worker/anthropic-proxy.js",
  "compatibility_date": "2026-04-06",
  // CORS 許可 Origin はここで版管理する（source of truth）。
  // 以前はダッシュボードの plain-text var だけに置いていたため、
  // コード側の DEFAULT_ALLOWED を編集しても env.ALLOWED_ORIGINS が
  // 優先されて反映されず、新 Origin (agewaller.github.io) が
  // preflight で弾かれて「通信に失敗」になった。vars に明記すれば
  // deploy で確実に上書きされる。
  // worker/anthropic-proxy.js の DEFAULT_ALLOWED と必ず一致させること。
  "vars": {
    "ALLOWED_ORIGINS": "https://cares.advisers.jp,https://cares-staging.agewaller.workers.dev,https://agewaller.github.io"
  },
  // keep_vars: true は、ここに書かない他の dashboard var
  // (FIREBASE_PROJECT_ID) を deploy で消さないために維持する。
  // vars に書いた ALLOWED_ORIGINS は deploy で適用される。
  "keep_vars": true,
  "observability": {
    "enabled": true
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
