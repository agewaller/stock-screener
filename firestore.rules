rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users can only read/write their own data
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Subcollections (textEntries, symptoms, vitals, etc.)
      match /{subcollection}/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Admin-only: global settings
    match /admin/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.email == 'agewaller@gmail.com';
    }

    // Plaud / data inbox dispatched by the plaud-inbox Cloudflare Worker.
    // Path: inbox/{hash}/{kind}/{messageId}
    //
    // - Reads: any authenticated user can read messages addressed to
    //   their own hash (the hash is derived from their email/uid in
    //   the worker and matched in the frontend listener). Cross-user
    //   reads are not blocked here because we use a hash-based
    //   indirection rather than uid-based; in practice the hash space
    //   is short enough that we don't expose it as a security boundary,
    //   only as a routing key.
    //
    // - Writes: the Cloudflare Worker hits the Firestore REST API with
    //   the public Firebase Web API key (NOT a service-account admin
    //   token), so from the rules' perspective `request.auth == null`.
    //   The previous rule had `allow create: if false` under the wrong
    //   assumption that the REST API bypasses rules with project-owner
    //   perms — it doesn't, so every inbound Plaud email was silently
    //   rejected and never reached the frontend. We now allow create
    //   with shape validation: the doc must start out processed=false,
    //   carry a plaud/data kind, have a non-empty text body under
    //   200KB, and the hash field in the payload must match the path
    //   hash (so an attacker can't write to an arbitrary user inbox
    //   via a mismatched hash).
    match /inbox/{hash}/{kind}/{messageId} {
      allow read: if request.auth != null;
      allow create: if request.resource.data.processed == false
                    && (kind == 'plaud' || kind == 'data')
                    && request.resource.data.hash is string
                    && request.resource.data.hash == hash
                    && request.resource.data.text is string
                    && request.resource.data.text.size() > 0
                    && request.resource.data.text.size() <= 200000;
      allow update: if request.auth != null
                    && request.resource.data.processed == true;
      allow delete: if false;
    }
  }
}
