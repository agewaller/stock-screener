# --- Site ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Supabase ---
# SERVICE_ROLE_KEY is server-only. NEVER expose to client.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# --- Resend (email delivery) ---
RESEND_API_KEY=
ALERT_FROM_EMAIL=alerts@example.com
ALERT_FROM_NAME=Japan Sovereignty Risk Monitor

# --- Alert thresholds (defaults; subscribers can override per-account) ---
ALERT_MIN_LEVEL=2
ALERT_MIN_SCORE_DELTA_1D=0.35
ALERT_MIN_SCORE_DELTA_7D=0.60
ALERT_COOLDOWN_HOURS=12

# --- Cron / Send-Alerts API protection ---
# Required header on /api/send-alerts: Authorization: Bearer <CRON_SECRET>
CRON_SECRET=
